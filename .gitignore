# The SQLite database is built on startup from the app's own content, so it
# should never be committed — it's regenerated every run.
*.db
*.db-journal

# Python bits
__pycache__/
*.pyc
.venv/
venv/

# Scratch transfer / snapshot folders the cloud session uses to move files safely
# (so they can never be committed by accident, even with `git add -A`).
_to_delete/
_xfer/
.fd_*.py
.*.snapshot
